-- [[ COORDENADA ÚNICA DE DESTINO ]]
local COORDENADA_UNICA = CFrame.new(89, 3, 579) * CFrame.fromEulerAnglesXYZ(0, math.rad(269), 0)

-- [[ FUNÇÃO PRINCIPAL DE TELETRANSPORTE E DISPARO ]]
local function executarSpawnCarro(veiculoID)
    local character = LocalPlayer.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local remote = ReplicatedStorage:FindFirstChild("RE") and ReplicatedStorage.RE:FindFirstChild("1Ca1r")
    
    if rootPart and remote then
        local posicaoOriginal = rootPart.CFrame
        local velocidadeOriginal = rootPart.AssemblyLinearVelocity
        
        rootPart.CFrame = COORDENADA_UNICA
        task.wait(2)
        
        local args = {"PickingCar", veiculoID, "Event"}
        remote:FireServer(unpack(args))
        
        task.wait(0.15)
        rootPart.CFrame = posicaoOriginal
        rootPart.AssemblyLinearVelocity = velocidadeOriginal
    end
end

-- [[ LÓGICA DE INTERAÇÃO COM HELICÓPTERO A DISTÂNCIA ]]
local function obterSpawnerMaisProximo()
    local character = LocalPlayer.Character
    local meuHRP = character and character:FindFirstChild("HumanoidRootPart")
    if not meuHRP then return nil end
    
    local menorDistancia = math.huge
    local spawnerAlvo = nil
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj.Name == "AirVehicleSpawner" and obj:IsA("Model") then
            local pPart = obj.PrimaryPart or obj:FindFirstChild("Button") or obj:FindFirstChildOfClass("BasePart")
            if pPart then
                local dist = (meuHRP.Position - pPart.Position).Magnitude
                if dist < menorDistancia then
                    menorDistancia = dist
                    spawnerAlvo = obj
                end
            end
        end
    end
    return spawnerAlvo
end

local function clonarPainelHelicoptero()
    for _, objeto in pairs(Workspace:GetDescendants()) do
        if objeto:IsA("ClickDetector") or objeto:IsA("ProximityPrompt") then
            objeto.MaxActivationDistance = math.huge
        end
    end

    local spawnerProximo = obterSpawnerMaisProximo()
    if spawnerProximo then
        local botaoFisico = spawnerProximo:FindFirstChild("Button")
        if botaoFisico then
            local clickDetector = botaoFisico:FindFirstChildOfClass("ClickDetector")
            local proximityPrompt = botaoFisico:FindFirstChildOfClass("ProximityPrompt")
            
            if clickDetector and fireclickdetector then
                fireclickdetector(clickDetector)
            elseif proximityPrompt and fireproximityprompt then
                fireproximityprompt(proximityPrompt)
            end
        end
    end
end

-- [[ CONSTRUTOR DE BOTÕES INTERATIVOS ]]
local function criarBotaoVeiculo(texto, veiculoID, tipoAcao, ordem)
    local TextButton = Instance.new("TextButton")
    TextButton.Name = texto .. "Btn"
    TextButton.Size = UDim2.new(1, 0, 0, 24)
    TextButton.BackgroundTransparency = 1
    TextButton.Text = texto
    TextButton.Font = Enum.Font.SpecialElite
    TextButton.TextSize = 18
    TextButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    TextButton.TextXAlignment = Enum.TextXAlignment.Left
    TextButton.LayoutOrder = ordem
    TextButton.ZIndex = 3
    TextButton.Parent = ButtonsContainer

    -- Efeitos Hover
    TextButton.MouseEnter:Connect(function()
        TweenService:Create(TextButton, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(160, 160, 160)}):Play()
    end)
    TextButton.MouseLeave:Connect(function()
        TweenService:Create(TextButton, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
    end)

    -- Clique
    TextButton.MouseButton1Click:Connect(function()
        if tipoAcao == "Carro" then
            executarSpawnCarro(veiculoID)
        elseif tipoAcao == "Helicoptero" then
            clonarPainelHelicoptero()
        end
    end)
end

